{  
  "manifest_version": 3,  
  "name": "Interview Copilot",  
  "version": "1.0.0",  
  "description": "AI-powered interview assistant",  
  "permissions": [  
    "activeTab"  
  ],  
  "host_permissions": [  
    "https://interview-copilot-backend-main.up.railway.app/*"  
  ],  
  "background": {  
    "service_worker": "background.js"  
  },  
  "action": {  
    "default_popup": "index.html",  
    "default_icon": {  
      "16": "icon.png",  
      "48": "icon.png",  
      "128": "icon.png"  
    }  
  }  
}  