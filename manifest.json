{  
  "manifest_version": 3,  
  "name": "Interview Copilot",  
  "version": "1.0.0",  
  "description": "Real-time interview assistance",  
  "permissions": [],  
  "action": {  
    "default_popup": "index.html",  
    "default_icon": {  
      "16": "icon.png",  
      "48": "icon.png",  
      "128": "icon.png"  
    }  
  },  
  "host_permissions": ["<all_urls>"]  
}  